<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_disciplinary" model="ir.module.category">
        <field name="name">Disciplinary</field>
    </record>

    <record id="group_disciplinary_admin" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_category_disciplinary"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_disciplinary_directivo" model="res.groups">
        <field name="name">Equipo directivo</field>
        <field name="category_id" ref="module_category_disciplinary"/>
    </record>

    <record id="group_disciplinary_profesor" model="res.groups">
        <field name="name">Profesor</field>
        <field name="category_id" ref="module_category_disciplinary"/>
    </record>

    <!-- Regla: profesor puede leer todos los expedientes -->
    <record id="rule_disciplinary_profesor_read" model="ir.rule">
        <field name="name">Profesor: puede leer todos los expedientes</field>
        <field name="model_id" ref="model_ryc_student_disciplinary"/>
        <field name="groups" eval="[(4, ref('group_disciplinary_profesor'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- Regla: profesor solo puede escribir/borrar/crear expedientes propios -->
    <record id="rule_disciplinary_profesor_own" model="ir.rule">
        <field name="name">Profesor: solo gestiona sus propios expedientes</field>
        <field name="model_id" ref="model_ryc_student_disciplinary"/>
        <field name="groups" eval="[(4, ref('group_disciplinary_profesor'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read">0</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

    <!-- Regla: profesor puede leer todos los alumnos -->
    <record id="rule_student_profesor_read" model="ir.rule">
        <field name="name">Profesor: puede leer todos los alumnos</field>
        <field name="model_id" ref="model_ryc_student"/>
        <field name="groups" eval="[(4, ref('group_disciplinary_profesor'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- Regla: profesor solo puede escribir alumnos de su grupo tutelado -->
    <record id="rule_student_profesor_own" model="ir.rule">
        <field name="name">Profesor: solo escribe alumnos de su tutoría</field>
        <field name="model_id" ref="model_ryc_student"/>
        <field name="groups" eval="[(4, ref('group_disciplinary_profesor'))]"/>
        <field name="domain_force">[('group_id.tutor_id.user_id', '=', user.id)]</field>
        <field name="perm_read">0</field>
        <field name="perm_write">1</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
</odoo>
