<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista search de estudiantes -->
    <record id="view_ryc_student_search" model="ir.ui.view">
        <field name="name">ryc.student.search</field>
        <field name="model">ryc.student</field>
        <field name="arch" type="xml">
            <search string="Estudiantes">
                <field name="course_id" string="Curso"/>
                <field name="group_id" string="Grupo"/>
                <field name="sex" string="Sexo"/>
                <field name="full_name" string="Nombre completo"/>
                <field name="last_name" string="Apellidos"/>
                <field name="email" string="Correo electrónico"/>
                <separator/>
                <filter string="Mayores de edad" name="adults" domain="[('age', '&gt;=', 18)]"/>
                <filter string="Menores de edad" name="minors" domain="[('age', '&lt;', 18)]"/>
                <filter string="Con partes de incidencia" name="with_incidents" domain="[('disciplinary_ids', '!=', False)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Grupo" name="group_by_group" context="{'group_by': 'group_id'}"/>
                    <filter string="Curso" name="group_by_course" context="{'group_by': 'course_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista tree principal de estudiantes -->
    <record id="view_ryc_student_tree" model="ir.ui.view">
        <field name="name">ryc.student.tree</field>
        <field name="model">ryc.student</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_code"/>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="course_id"/>
                <field name="group_id"/>
                <field name="sex"/>
                <field name="age"/>
            </tree>
        </field>
    </record>

    <!-- Vista form principal de estudiantes -->
    <record id="view_ryc_student_form" model="ir.ui.view">
        <field name="name">ryc.student.form</field>
        <field name="model">ryc.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="first_name" placeholder="Nombre"/>
                            <field name="last_name" placeholder="Apellidos"/>
                        </h1>
                        <h2>
                            <field name="student_code" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Datos personales">
                            <field name="email"/>
                            <field name="sex"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                        </group>
                        <group string="Datos académicos">
                            <field name="course_id"/>
                            <field name="group_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expedientes disciplinarios">
                            <field name="disciplinary_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="incident_type"/>
                                    <field name="incident"/>
                                    <field name="time_slot"/>
                                    <field name="ryc_teacher"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista tree para Partes Disciplinarios -->
    <record id="view_ryc_student_partes_tree" model="ir.ui.view">
        <field name="name">ryc.student.partes.tree</field>
        <field name="model">ryc.student</field>
        <field name="arch" type="xml">
            <tree>
                <field name="full_name"/>
                <field name="group_id"/>
                <field name="disciplinary_count"/>
            </tree>
        </field>
    </record>

    <!-- Vista form para Partes Disciplinarios -->
    <record id="view_ryc_student_partes_form" model="ir.ui.view">
        <field name="name">ryc.student.partes.form</field>
        <field name="model">ryc.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="full_name" readonly="1"/>
                        </h1>
                    </div>
                    <field name="disciplinary_ids">
                        <tree>
                            <field name="date"/>
                            <field name="incident_type"/>
                            <field name="incident"/>
                            <field name="time_slot"/>
                            <field name="ryc_teacher"/>
                        </tree>
                    </field>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
