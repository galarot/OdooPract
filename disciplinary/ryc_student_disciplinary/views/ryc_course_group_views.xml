<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ryc_course_group_search" model="ir.ui.view">
        <field name="name">ryc.course.group.search</field>
        <field name="model">ryc.course.group</field>
        <field name="arch" type="xml">
            <search string="Grupos">
                <field name="code" string="Código"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Curso" name="group_by_course" context="{'group_by': 'course_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ryc_course_group_tree" model="ir.ui.view">
        <field name="name">ryc.course.group.tree</field>
        <field name="model">ryc.course.group</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="course_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="view_ryc_course_group_form" model="ir.ui.view">
        <field name="name">ryc.course.group.form</field>
        <field name="model">ryc.course.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del grupo"/>
                        </h1>
                        <h2>
                            <field name="code" placeholder="Código"/>
                        </h2>
                    </div>
                    <group>
                        <field name="course_ids" widget="many2many_tags"/>
                        <field name="tutor_id"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
