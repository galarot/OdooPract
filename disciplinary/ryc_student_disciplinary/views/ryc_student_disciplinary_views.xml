<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista search de expedientes disciplinarios -->
    <record id="view_ryc_student_disciplinary_search" model="ir.ui.view">
        <field name="name">ryc.student.disciplinary.search</field>
        <field name="model">ryc.student.disciplinary</field>
        <field name="arch" type="xml">
            <search string="Partes de incidencia">
                <field name="ryc_student" string="Estudiante"/>
                <field name="date" string="Fecha"/>
                <field name="ryc_teacher" string="Profesor"/>
                <separator/>
                <filter string="Parte de disciplina" name="discipline_report" domain="[('incident_type', '=', 'discipline_report')]"/>
                <filter string="Falta leve" name="minor_offense" domain="[('incident_type', '=', 'minor_offense')]"/>
                <filter string="Amonestación" name="warning" domain="[('incident_type', '=', 'warning')]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Conducta" name="group_by_incident" context="{'group_by': 'incident'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista tree de expedientes disciplinarios -->
    <record id="view_ryc_student_disciplinary_tree" model="ir.ui.view">
        <field name="name">ryc.student.disciplinary.tree</field>
        <field name="model">ryc.student.disciplinary</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ryc_student"/>
                <field name="date"/>
                <field name="incident_type"/>
                <field name="incident"/>
                <field name="time_slot"/>
                <field name="ryc_teacher"/>
            </tree>
        </field>
    </record>

    <!-- Vista form de expedientes disciplinarios -->
    <record id="view_ryc_student_disciplinary_form" model="ir.ui.view">
        <field name="name">ryc.student.disciplinary.form</field>
        <field name="model">ryc.student.disciplinary</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="ryc_student" placeholder="Alumno"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Incidencia">
                            <field name="incident_type"/>
                            <field name="incident"/>
                            <field name="date"/>
                            <field name="time_slot"/>
                        </group>
                        <group string="Detalles">
                            <field name="ryc_teacher"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
