<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista tree principal de cursos -->
    <record id="view_ryc_course_tree" model="ir.ui.view">
        <field name="name">ryc.course.tree</field>
        <field name="model">ryc.course</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="level_id"/>
            </tree>
        </field>
    </record>

    <!-- Vista form principal de cursos -->
    <record id="view_ryc_course_form" model="ir.ui.view">
        <field name="name">ryc.course.form</field>
        <field name="model">ryc.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del curso"/>
                        </h1>
                        <h2>
                            <field name="code" placeholder="Código"/>
                        </h2>
                    </div>
                    <group>
                        <field name="level_id"/>
                    </group>
                    <notebook>
                        <page string="Grupos">
                            <field name="group_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista form para Por Cursos: muestra alumnos del curso -->
    <record id="view_ryc_course_cursos_form" model="ir.ui.view">
        <field name="name">ryc.course.cursos.form</field>
        <field name="model">ryc.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="code" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <field name="level_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Alumnos">
                            <field name="student_ids">
                                <tree>
                                    <field name="full_name"/>
                                    <field name="group_id"/>
                                    <field name="sex"/>
                                    <field name="age"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
