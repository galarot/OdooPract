<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

  <t t-name="awesome_owl.autobaremo" owl="1">
    <div class="container-xl px-lg-5 py-3">
      <div class="alert alert-warning text-center shadow-sm mb-5 fs-5 fw-semibold"
             role="alert">
          Los candidatos que estén en posesión de distintas titulaciones deben realizar tantos autobaremos y adjuntar tantos documentos como titulaciones tengan.<br></br>
          Los archivos adjuntos deben de estar en formato PDF.
        </div>
      <!-- ══════════════════════════════════
           DATOS PERSONALES
      ══════════════════════════════════════ -->
      <div class="mb-3">
        <label class="form-label fw-semibold fs-6" for="fnombre">Nombre</label>
        <input class="form-control form-control-lg"
               type="text"
               id="fnombre"
               name="fnombre"
               t-model.lazy.trim="this.state.nombre"
               t-ref="nombre"
               required="True"
               placeholder="Introduce tu nombre"/>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold fs-6" for="fapellidos">Apellidos</label>
        <input class="form-control form-control-lg"
               type="text"
               id="fapellidos"
               name="fapellidos"
               t-model.lazy.trim="this.state.apellidos"
               t-ref="apellidos"
               placeholder="Introduce tus apellidos"/>
      </div>

      <div class="mb-3" t-ref="titulacion">
        <label class="form-label fw-semibold fs-6">Titulación</label>
        <Titulaciones onSelect="updateSelected"/>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold fs-6" for="ffechaexpedicion">Fecha de expedición del título</label>
        <input class="form-control form-control-lg" placeholder="dd-mm-yyyy" type="text"
               id="ffechaexpedicion" name="ffechaexpedicion"
               t-model.lazy.trim="this.state.fecha_expedicion"
              t-ref="fecha_expedicion"/>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold fs-6" for="fcorreoe">Correo electrónico</label>
        <input class="form-control form-control-lg" type="email" id="fcorreoe" name="fcorreoe"
               placeholder="correo@ejemplo.com" t-model.lazy.trim="this.state.email" t-ref="email"/>
      </div>

      <hr class="my-4"/>

      <!-- ══════════════════════════════════
           1. MÉRITOS ACADÉMICOS
      ══════════════════════════════════════ -->
      <h2 class="text-center bg-primary text-white rounded p-3 fs-5 mb-3">
        1. MÉRITOS ACADÉMICOS
        <small class="d-block fs-6 fw-normal opacity-75">(máx. 2 puntos)</small>
      </h2>

      <!-- 1.1 -->
      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
        1.1. Titulación exigida
      </h3>
      <p class="text-muted small fst-italic mb-2">Cada título solo se podrá valorar una vez:</p>

      <div class="form-check p-3 border rounded mb-2">
        <input class="form-check-input mt-1" type="radio" t-model="this.state.ma_titulacion_exigida"
               name="ma_titulacion_exigida" id="radio1" value="0.5"
              t-ref="titulacion_exigida"/>
        <label class="form-check-label fs-6 ms-2" for="radio1">
          1.1.1 Licenciado o Grado de más de 240 créditos <strong>(0,5 puntos)</strong>
        </label>
      </div>
      <div class="form-check p-3 border rounded mb-2">
        <input class="form-check-input mt-1" type="radio" t-model="this.state.ma_titulacion_exigida" name="ma_titulacion_exigida" id="radio2" value="0.25"/>
        <label class="form-check-label fs-6 ms-2" for="radio2">
          1.1.2 Diplomado o Grado de menos de 240 créditos <strong>(0,25 puntos)</strong>
        </label>
      </div>
      <div class="mb-3">
        <label class="form-label fs-6" for="file11">Adjuntar título universitario</label>
        <input class="form-control form-control-lg" t-ref="file11" type="file" id="file11"/>
      </div>

      <hr class="my-2"/>

      <!-- 1.2 -->
      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-1">
        1.2. Expediente académico
      </h3>
      <p class="text-muted small mb-2">Nota media del título presentado para la plaza a desempeñar</p>

      <div class="form-check p-3 border rounded mb-2">
        <input t-model="this.state.ma_expediente_academico" class="form-check-input mt-1" type="radio" name="expediente"
               id="radio3" value="0.5" t-ref="expediente_academico"/>
        <label class="form-check-label fs-6 ms-2" for="radio3">
          1.2.1. Matrícula <strong>(0,5 puntos)</strong>
        </label>
      </div>
      <div class="form-check p-3 border rounded mb-2">
        <input t-model="this.state.ma_expediente_academico" class="form-check-input mt-1" type="radio" name="expediente" id="radio4" value="0.3"/>
        <label class="form-check-label fs-6 ms-2" for="radio4">
          1.2.2. Sobresaliente <strong>(0,3 puntos)</strong>
        </label>
      </div>
      <div class="form-check p-3 border rounded mb-2">
        <input t-model="this.state.ma_expediente_academico" class="form-check-input mt-1" type="radio" name="expediente" id="radio5" value="0.2"/>
        <label class="form-check-label fs-6 ms-2" for="radio5">
          1.2.3. Notable <strong>(0,2 puntos)</strong>
        </label>
      </div>
      <div class="form-check p-3 border rounded mb-2">
        <input t-model="this.state.ma_expediente_academico" class="form-check-input mt-1" type="radio" name="expediente" id="radio6" value="0"/>
        <label class="form-check-label fs-6 ms-2" for="radio6">
          1.2.4. Otra <strong>(0 puntos)</strong>
        </label>
      </div>
      <div class="mb-3">
        <label class="form-label fs-6" for="file12">Adjuntar certificado de notas</label>
        <input class="form-control form-control-lg" t-ref="file12" type="file" id="file12"/>
      </div>

      <hr class="my-2"/>

      <!-- 1.3 -->
      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
        1.3. Titulación habilitante
      </h3>

      <div class="form-check p-3 border rounded mb-2">
        <input t-model="this.state.maescap" class="form-check-input mt-1" type="checkbox"
               id="flexCheckDefault" t-ref="maescap"/>
        <label class="form-check-label fs-6 ms-2" for="flexCheckDefault">
          Posesión del
          <u title="Certificado de Aptitud Pedagógica" style="text-decoration-style:dotted">CAP</u>
          o
          <u title="Master Universitario de Enseñanza Secundaria obligatoria y bachillerato, formación profesional y enseñanza de idiomas" style="text-decoration-style:dotted">MAES</u>
        </label>
      </div>
      <div class="mb-3">
        <label class="form-label fs-6" for="file13">Adjuntar CAP o MAES</label>
        <input class="form-control form-control-lg" type="file" id="file13" t-ref="file13"/>
      </div>

      <hr class="my-2"/>

      <!-- 1.4 -->
      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
        1.4. Títulos <b>distintos</b> al presentado para la plaza
      </h3>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fdoctor">
            1.4.1. Doctor
            <span class="d-block text-muted small fw-normal">(0,75 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fdoctor" class="form-select form-select-lg" aria-label="Doctor" t-model="this.state.ma_td_doctor">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fsuficiencia">
            1.4.2. Suficiencia investigadora
            <span class="d-block text-muted small fw-normal">(0,5 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fsuficiencia" class="form-select form-select-lg" aria-label="Suficiencia investigadora" t-model="this.state.ma_td_si">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fotromaster">
            1.4.3. Otro Máster (excl. CAP/MAES)
            <span class="d-block text-muted small fw-normal">(0,4 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fotromaster" class="form-select form-select-lg" aria-label="Otro máster" t-model="this.state.ma_td_otra_mas">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fotralicenciatura">
            1.4.4. Otra licenciatura o grado +240 créditos
            <span class="d-block text-muted small fw-normal">(0,4 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fotralicenciatura" class="form-select form-select-lg" aria-label="Otra licenciatura" t-model="this.state.ma_td_otra_lic">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fdiplomatura">
            1.4.5. Otra diplomatura o grado -240 créditos
            <span class="d-block text-muted small fw-normal">(0,25 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fdiplomatura" class="form-select form-select-lg" aria-label="Otra diplomatura" t-model="this.state.ma_td_otra_dip">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fcfgs">
            1.4.6. CFGS - FP2
            <span class="d-block text-muted small fw-normal">(0,2 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fcfgs" class="form-select form-select-lg" aria-label="CFGS FP2" t-model="this.state.ma_td_cfgs">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option>
          </select>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fs-6" for="file14">Adjuntar títulos seleccionados</label>
        <input class="form-control form-control-lg" type="file" id="file14" multiple="true" t-ref="file14"/>
      </div>

      <hr class="my-2"/>

      <!-- 1.5 -->
      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
        1.5. Títulos oficiales de idiomas
      </h3>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fingles">1.5.1. Inglés</label>
        </div>
        <div class="col-4">
          <select id="fingles" class="form-select form-select-lg" aria-label="Inglés" t-model="this.state.ingles">
            <option value="0">Ninguno</option>
            <option value="A1">A1</option><option value="A2">A2</option>
            <option value="B1">B1</option><option value="B2">B2</option>
            <option value="C1">C1</option><option value="C2">C2</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="ffrances">1.5.2. Francés</label>
        </div>
        <div class="col-4">
          <select id="ffrances" class="form-select form-select-lg" aria-label="Francés" t-model="this.state.frances">
            <option value="0">Ninguno</option>
            <option value="A1">A1</option><option value="A2">A2</option>
            <option value="B1">B1</option><option value="B2">B2</option>
            <option value="C1">C1</option><option value="C2">C2</option>
          </select>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fs-6" for="file15">Adjuntar títulos oficiales de idiomas</label>
        <input class="form-control form-control-lg" type="file" id="file15" multiple="true" t-ref="file15"/>
      </div>

      <hr class="my-4"/>

      <!-- ══════════════════════════════════
           2. CURSOS REALIZADOS
      ══════════════════════════════════════ -->
