          </select>
        </div>
      </div>

      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
        3.2. En otros centros de enseñanza reglada
      </h3>

      <div class="row align-items-center g-2 mb-3">
        <div class="col-8">
          <label class="form-label fs-6 mb-0" for="fotromes">
            3.2.1. Por mes o fracción
            <span class="d-block text-muted small fw-normal">(0,01 puntos)</span>
          </label>
        </div>
        <div class="col-4">
          <select id="fotromes" class="form-select form-select-lg" aria-label="Otros Mes"
                  t-model="this.state.ed_meses_trabajados_er">
            <option value="0">0</option>
            <option value="1">1</option><option value="2">2</option><option value="3">3</option>
