          <option value="970">970 h</option><option value="980">980 h</option><option value="990">990 h</option>
          <option value="1000">+1000 h</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label fs-6" for="file2">Adjuntar acreditaciones de los diferentes cursos</label>
        <input class="form-control form-control-lg" type="file" id="file2" multiple="true" t-ref="file2"/>
      </div>

      <hr class="my-4"/>

      <!-- ══════════════════════════════════
           3. EXPERIENCIA DOCENTE
      ══════════════════════════════════════ -->
      <h2 class="text-center bg-primary text-white rounded p-3 fs-5 mb-3">
        3. EXPERIENCIA DOCENTE
        <small class="d-block fs-6 fw-normal opacity-75">(máx. 2 puntos)</small>
      </h2>

      <h3 class="fs-6 fw-bold border-start border-primary border-3 ps-2 py-1 bg-light mt-3 mb-2">
