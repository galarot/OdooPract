<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="awesome_clicker.AwesomeClicker" owl="1">
        <div class="p-3 text-center awesome_clicker_container">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1>Awesome Clicker Game</h1>
                <button class="btn btn-danger" t-on-click="() => this.clicker.reset()">
                    <i/> Reseteo
                </button>
            </div>
            <div class="display-1 my-4">
                <t t-esc="clicker.clicks"/> Clicks
            </div>
            
            <button class="btn btn-lg btn-success mb-5" t-on-click="() => this.clicker.increment(100)">
                Increment +100
            </button>

            <button t-if="(clicker.clicks >= 50000000 and clicker.rebirthLevel == 0) or (clicker.clicks >= 300000000 and clicker.rebirthLevel == 1) or (clicker.clicks >= 750000000 and clicker.rebirthLevel == 2)" class="btn btn-lg btn-danger ms-2 mb-5" t-on-click="() => this.clicker.rebirth()">
                Rebirth (x<t t-esc="clicker.rebirthLevel + 1"/>)
            </button>
            <span t-if="clicker.rebirthLevel > 0" class="ms-3 badge bg-warning p-2">Rebirth Level: <t t-esc="clicker.rebirthLevel"/> (x<t t-esc="clicker.rebirthMultiplier"/>)</span>

            <div class="my-4">
                <img t-att-src="'/awesome_clicker/static/src/img/' + clicker.getGokuPhase() + '.png'" 
                     style="max-width: 300px; height: auto;" 
                     alt="Goku Evolution"/>
            </div>

            <Notebook orientation="'horizontal'">
                <t t-set-slot="page_1" title="'Clicks'" isVisible="true">
                    <div class="border-top pt-4">
                        <div class="mb-3">
                            <h3>SuperBots: <t t-esc="clicker.superBots"/> (1 click/s)</h3>
                            <button class="btn btn-success" t-att-disabled="clicker.clicks &lt; 500" t-on-click="() => this.clicker.buySuperBot()">
                                Buy SuperBot (500)
                            </button>
                        </div>
                        <div t-if="clicker.level >= 1" class="mb-3">
                            <h3>ClickBots: <t t-esc="clicker.clickBots"/> (100 clicks/10s)</h3>
                            <button class="btn btn-primary" t-att-disabled="clicker.clicks &lt; 1000" t-on-click="() => this.clicker.buyClickBot()">
                                Buy ClickBot (1k)
                            </button>
                        </div>
                        <div t-if="clicker.level >= 2" class="mb-3">
                            <h3>BigBots: <t t-esc="clicker.bigBots"/> (1000 clicks/10s)</h3>
                            <button class="btn btn-warning" t-att-disabled="clicker.clicks &lt; 5000" t-on-click="() => this.clicker.buyBigBot()">
                                Buy BigBot (5k)
                            </button>
                        </div>
                        <div t-if="clicker.level >= 3" class="mb-3">
                            <h3>Power Multiplier: x<t t-esc="clicker.multiplier"/></h3>
                            <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 50000" t-on-click="() => this.clicker.buyMultiplier()">
                                Buy Power Level (50k)
                            </button>
                        </div>
                    </div>
                </t>

                <t t-set-slot="page_2" title="'Trees and Fruits'" isVisible="true">
                    <div class="border-top pt-4">
                        <div t-if="clicker.clicks >= 1000000 or clicker.totalTrees > 0" class="mb-3">
                            <h3>Trees</h3>
                            <div class="row justify-content-center">
                                <div class="col-auto card m-2 p-3">
                                    <p><t t-esc="clicker.trees.pear"/>x pearTree (1 pear /30s)</p>
                                    <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 1000000" t-on-click="() => this.clicker.buyTree('pear')">
                                        Buy pearTree (1M)
                                    </button>
                                </div>
                                <div class="col-auto card m-2 p-3">
                                    <p><t t-esc="clicker.trees.cherry"/>x cherryTree (1 cherry /30s)</p>
                                    <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 1000000" t-on-click="() => this.clicker.buyTree('cherry')">
                                        Buy cherryTree (1M)
                                    </button>
                                </div>
                                <div class="col-auto card m-2 p-3">
                                    <p><t t-esc="clicker.trees.peach"/>x peachTree (1 peach /30s)</p>
                                    <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 1500000" t-on-click="() => this.clicker.buyTree('peach')">
                                        Buy peachTree (1.5M)
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div t-if="clicker.totalFruits > 0" class="mb-3">
                            <h3>Fruits Collected</h3>
                            <div class="d-flex justify-content-center gap-3">
                                <span class="badge bg-secondary p-2"><t t-esc="clicker.fruits.pear"/> Pears</span>
                                <span class="badge bg-secondary p-2"><t t-esc="clicker.fruits.cherry"/> Cherries</span>
                                <span class="badge bg-secondary p-2"><t t-esc="clicker.fruits.peach"/> Peaches</span>
                            </div>
                        </div>
                    </div>
                </t>
            </Notebook>
        </div>
    </t>
</templates>