<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
<t t-name="awesome_clicker.AwesomeClicker">
    <div class="p-3 text-center">
        <h1>Awesome Clicker Game</h1>
        <div class="display-1 my-4">
            <t t-esc="clicker.clicks"/> Clicks
        </div>
        
        <button class="btn btn-lg btn-success mb-5" t-on-click="() => this.clicker.increment(1000000)">
            Increment +1000000
        </button>

        <Notebook orientation="'horizontal'">
            <t t-set-slot="page_1" title="'Clicks'" isVisible="true">
                <div class="border-top pt-4">
                    <div t-if="clicker.level >= 1" class="mb-3">
                        <h3>ClickBots: <t t-esc="clicker.clickBots"/> (10 clicks/10s)</h3>
                        <button class="btn btn-primary" t-att-disabled="clicker.clicks &lt; 1000" t-on-click="() => this.clicker.buyClickBot()">
                            Buy ClickBot (1k)
                        </button>
                    </div>
                    <div t-if="clicker.level >= 2" class="mb-3">
                        <h3>BigBots: <t t-esc="clicker.bigBots"/> (100 clicks/10s)</h3>
                        <button class="btn btn-warning" t-att-disabled="clicker.clicks &lt; 5000" t-on-click="() => this.clicker.buyBigBot()">
                            Buy BigBot (5k)
                        </button>
                    </div>
                    <div t-if="clicker.level >= 3" class="mb-3">
                        <h3>Power Multiplier: x<t t-esc="clicker.multiplier"/></h3>
                        <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 50000" t-on-click="() => this.clicker.buyMultiplier()">
                            Buy Power Level (50k)
                        </button>
                    </div>
                </div>
            </t>
            <t t-set-slot="page_2" title="'Trees and Fruits'" isVisible="true">
                <div class="border-top pt-4">
                    <div t-if="clicker.clicks >= 1000000 or clicker.totalTrees > 0" class="mb-3">
                        <h3>Trees</h3>
                        <div class="row justify-content-center">
                            <div class="col-auto">
                                <p><t t-esc="clicker.trees.pear"/> pearTree (1 pear /30s)</p>
                                <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 1000000" t-on-click="() => this.clicker.buyTree('pear')">
                                    Buy pearTree (1M)
                                </button>
                            </div>
                            <div class="col-auto">
                                <p><t t-esc="clicker.trees.cherry"/> cherryTree (1 cherry /30s)</p>
                                <button class="btn btn-info" t-att-disabled="clicker.clicks &lt; 1000000" t-on-click="() => this.clicker.buyTree('cherry')">
                                    Buy cherryTree (1M)
                                </button>
                            </div>
                        </div>
                    </div>
                    <div t-if="clicker.totalFruits > 0" class="mb-3">
                        <h3>Fruits</h3>
                        <p>
                            <t t-esc="clicker.fruits.pear"/> pear(s) | <t t-esc="clicker.fruits.cherry"/> cherry(es)
                        </p>
                    </div>
                </div>
            </t>
        </Notebook>
    </div>
</t>
</templates>
